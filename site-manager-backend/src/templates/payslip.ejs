<!DOCTYPE html>
<html>
<head>
  <style>
    body { font-family: Arial, sans-serif; margin: 40px; }
    .header { text-align: center; margin-bottom: 20px; }
    .info { margin: 20px 0; }
    table { width: 100%; border-collapse: collapse; margin: 20px 0; }
    th, td { border: 1px solid #ddd; padding: 8px; text-align: left; }
    th { background-color: #f2f2f2; }
    .footer { margin-top: 40px; text-align: center; }
    .qr { float: right; }
  </style>
</head>
<body>
  <div class="header">
    <h1><%= companyName %></h1>
    <img src="<%= companyLogo %>" alt="Logo" width="150">
  </div>

  <div class="info">
    <p><strong>Worker:</strong> <%= worker.firstName %> <%= worker.lastName %> (<%= worker.employeeNo %>)</p>
    <p><strong>Site:</strong> <%= site.siteRefName %> (<%= site.clientName %>)</p>
    <p><strong>Month:</strong> <%= month %></p>
  </div>

  <table>
    <tr><th>Description</th><th>Amount (AED)</th></tr>
    <tr><td>Basic Salary</td><td><%= worker.basicSalary %></td></tr>
    <tr><td>Allowance</td><td><%= worker.allowance %></td></tr>
    <tr><td><strong>Total Salary</strong></td><td><strong><%= totalSalary %></strong></td></tr>
    <tr><td>OT Hours</td><td><%= otHr %></td></tr>
    <tr><td>OT Rate</td><td><%= otAedPerHr %></td></tr>
    <tr><td>Total OT</td><td><%= totalOtAed %></td></tr>
    <tr><td>Absent Days</td><td><%= absent %></td></tr>
    <tr><td>Absent Deduction</td><td><%= absentDeduction %></td></tr>
    <tr><td>Advance</td><td><%= advance %></td></tr>
    <tr><td><strong>Net Payable</strong></td><td><strong><%= totalSalaryPayable %></strong></td></tr>
  </table>

  <div class="footer">
    <img src="<%= qrCode %>" alt="QR" class="qr" width="100">
    <p>Authorized Signature: ____________________</p>
    <img src="<%= signature %>" alt="Signature" width="200">
  </div>
</body>
</html>